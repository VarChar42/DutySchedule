default_platform(:ios)

platform :ios do
  desc "Build and upload a new build to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    # The shared Kotlin framework is embedded via a Run Script build phase
    # in the Xcode project (./gradlew :shared:embedAndSignAppleFrameworkForXcode),
    # which Xcode invokes itself during build_app below with the right
    # ARCHS/SDK_NAME env vars set. Don't invoke that Gradle task separately
    # here — outside of an actual Xcode build it can't infer the target
    # architecture and fails.

    match(type: "appstore", api_key: api_key, readonly: false)

    increment_build_number(
      xcodeproj: "dutyscheduleIOS.xcodeproj",
      build_number: (latest_testflight_build_number(api_key: api_key) + 1).to_s
    )

    app_id = ENV["APP_IDENTIFIER"] || "me.emiliomini.dutyscheduleIOS"

    build_app(
      project: "dutyscheduleIOS.xcodeproj",
      scheme: "dutyscheduleIOS",
      export_method: "app-store",
      output_directory: "./build",
      disable_xcpretty: true, # stream raw xcodebuild output live instead of
                               # buffering each Run Script phase until it ends
      xcargs: [
        "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']}",
        "CODE_SIGN_STYLE=Manual",
        "CODE_SIGN_IDENTITY=\"Apple Distribution\"",
        "PROVISIONING_PROFILE_SPECIFIER=\"match AppStore #{app_id}\""
      ].join(" ")
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
